# Python (scripts are stdlib-only; these are runtime artifacts, not source)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local scratch / logs (never commit derived working files — see README "Conventions")
*.log
*.tmp
.env

# Tooling artifacts (browser automation snapshots/screenshots during data investigation)
.playwright-mcp/

# Normalized/derived outputs are regenerated from source via scripts; keep them out of
# source control (matches at any depth, e.g. sources/<source>/wgs84/)
wgs84/

# cleanup/ derived outputs — reprojected GeoJSON and the .osm.pbf exports are
# regenerated from sources via the cleanup scripts (the recipe is committed, not the output)
cleanup/normalized/
cleanup/osm/
cleanup/report.csv
